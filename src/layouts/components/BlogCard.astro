---
import config from "@/config/config.json";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, plainify } from "@/lib/utils/textConverter";
import ImageMod from "./ImageMod.astro";

const { blog_folder }: { blog_folder: string } = config.settings;
const { data, aosDelay } = Astro.props;
const { title, image, date, categories } = data.data;
---

<div
  data-aos="fade-up-sm"
  data-aos-delay={aosDelay}
  class="bg-body border border-border rounded-4xl p-8 group"
>
  {
    image && (
      <div class="overflow-hidden rounded-2xl mb-6">
        <ImageMod
          class="overflow-hidden w-full object-cover md:aspect-[16/9] rounded-2xl group-hover:scale-110 transition duration-700"
          src={image}
          alt={title}
          width={550}
          height={350}
          format="webp"
          loading={"eager"}
        />
      </div>
    )
  }

  <ul class="flex justify-between items-baseline mb-10 mt-8">
    <li class="mr-4 flex gap-2 flex-wrap">
      {
        categories.map((category: string) => (
          <p class="px-4 py-1 rounded-full bg-transparent border border-border text-xs w-fit font-semibold">
            {humanize(category)}
          </p>
        ))
      }
    </li>
    {
      date && (
        <li class="inline-block text-xs font-semibold">{dateFormat(date)}</li>
      )
    }
  </ul>

  <h4 class="mb-3 h6 font-semibold hover:text-secondary duration-200">
    <a href={`/${blog_folder}/${data.id}`}>
      {title}
    </a>
  </h4>
  <p class="mb-10 line-clamp-2">{plainify(data.body)}</p>
  <a class="btn btn-outline w-full" href={`/${blog_folder}/${data.id}`}>
    read more
  </a>
</div>
