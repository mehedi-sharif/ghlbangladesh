---
import { markdownify } from "@/lib/utils/textConverter";
import ImageMod from "./ImageMod.astro";
import type { CollectionEntry } from "astro:content";

type Props = {
  data: CollectionEntry<"reviewsSection">;
  isDonationPage?: Boolean;
};

const { data, isDonationPage = false } = Astro.props;
---

<div
  data-aos="fade-up-sm"
  data-aos-delay="200"
  class="swiper testimonial-slider"
>
  <div class="swiper-wrapper">
    {
      data.data.reviews.map((review) => (
        <div class="swiper-slide">
          <div
            class={`flex flex-col ${isDonationPage ? "items-center lg:items-start" : "items-center"} `}
          >
            {/* Stars Rating */}
            <div
              class="stars"
              style={{ "--rating": review.ratings }}
              aria-label="Rating from the company"
            />

            {/* Testimonial */}
            <p
              class={`${isDonationPage ? "h6 text-balance font-medium max-lg:text-center" : "h4 text-center font-semibold"}  mb-8 mt-4 text-text-dark/90 before:content-['“'] after:content-['”']`}
            >
              {review.content}
            </p>

            {/* User Info */}
            <div class="flex justify-between items-center">
              <div class="flex mt-auto items-center gap-2">
                <ImageMod
                  class="h-12 w-12 rounded-full object-cover border border-border"
                  src={review.avatar}
                  alt={review.name}
                  width={54}
                  height={54}
                />
                <div>
                  <h6
                    class="mb-1 text-sm text-text-dark font-semibold"
                    set:html={markdownify(review.name)}
                  />
                  <p
                    class="text-xs"
                    set:html={markdownify(review.designation)}
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      ))
    }
  </div>
  <div
    class="testimonial-slider-pagination mt-9 flex items-center justify-center text-center"
  >
  </div>
</div>

<script>
  import { Swiper } from "swiper";
  import "swiper/css";
  import "swiper/css/pagination";
  import { Autoplay, Pagination } from "swiper/modules";

  // astro:page-load event is fired when the page is loaded
  document.addEventListener("astro:page-load", () => {
    new Swiper(".testimonial-slider", {
      modules: [Pagination, Autoplay],
      spaceBetween: 24,
      loop: true,
      centeredSlides: true,
      autoplay: {
        delay: 2500,
        disableOnInteraction: false,
      },
      breakpoints: {
        0: {
          slidesPerView: 1,
        },
      },
    });
  });
</script>
