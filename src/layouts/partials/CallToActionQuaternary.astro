---
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";

const call_to_action = await getListPage(
  "ctaQuaternary",
  "call-to-action-quaternary"
);
if (!call_to_action.data.enable) {
  return null;
}
const { isNoSectionTop = false } = Astro.props;
---

<section
  data-aos="fade-up-sm"
  data-aos-delay={"150"}
  class={`section ${isNoSectionTop && "pt-0"}`}
>
  <div class="container">
    <div
      class={`${call_to_action.data.banner_color} rounded-4xl p-14 text-wrap break-words relative overflow-hidden`}
    >
      {/* Circle Background */}
      <div
        class="absolute top-[70%] lg:top-[55%] left-1/2 -translate-x-1/2 z-0 rounded-full bg-body/30"
        style="width: 100vw; height: 200vw;"
      >
      </div>

      <div class="relative z-10 flex flex-col items-center">
        <h3
          class="mb-4 font-semibold text-center"
          set:html={markdownify(call_to_action.data.title || "")}
        />
        <p
          class="mb-14 text-center text-balance"
          set:html={markdownify(call_to_action.data.description || "")}
        />
        {
          call_to_action.data.button?.enable && (
            <a
              href={call_to_action.data.button.link}
              class="btn btn-primary text-center"
            >
              {call_to_action.data.button.label}
            </a>
          )
        }
      </div>
    </div>
  </div>
</section>
