---
import ImageMod from "@/components/ImageMod.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import Counter from "../functional-component/Counter";

const call_to_action = await getListPage(
  "ctaSecondarySection",
  "call-to-action-secondary"
);
if (!call_to_action.data.enable) {
  return null;
}
const { title, image, description, buttons, facts } = call_to_action.data;

const { isNoSectionTop = false } = Astro.props;
---

<section
  data-aos="fade-up-sm"
  data-aos-delay={"150"}
  class={`section ${isNoSectionTop && "pt-0"}`}
>
  <div class="container">
    <div
      class="relative px-14 pt-18 bg-[url(/images/homepage/cta-bg-2.png)] bg-cover bg-center bg-no-repeat rounded-4xl overflow-hidden text-white/90"
    >
      {/* Content */}
      <h3
        class="mb-4 text-center text-white"
        set:html={markdownify(title || "")}
      />
      <p
        class="font-semibold text-center"
        set:html={markdownify(description || "")}
      />

      <ul class="flex flex-wrap justify-center gap-4 mt-6">
        {
          buttons?.map((button, i) =>
            button.enable ? (
              <li>
                <a
                  class={`btn ${i % 2 === 0 ? "btn-primary" : "btn-outline"}`}
                  href={button.link}
                >
                  {button.label}
                </a>
              </li>
            ) : null
          )
        }
      </ul>

      {/* Statistics */}
      <div
        class="flex flex-col lg:flex-row items-center pt-5 lg:justify-between max-lg:pb-40"
      >
        <div class="space-y-4 max-lg:mx-auto max-lg:text-center max-lg:mb-4">
          {
            title && (
              <h6
                class="text-base font-normal text-white"
                set:html={markdownify(facts.title || "")}
              />
            )
          }

          {
            description && (
              <p class="text-sm" set:html={markdownify(facts.content || "")} />
            )
          }

          <div class="flex items-center max-lg:justify-center -space-x-2">
            {
              facts?.team?.map((t, i) => (
                <div data-aos="fade-right-sm" data-aos-delay={i * 200 + 100}>
                  <ImageMod
                    width={50}
                    height={50}
                    class="w-9 aspect-square rounded-full bg-body"
                    src={t}
                    alt="Badge"
                  />
                </div>
              ))
            }
          </div>
          <p class="h6">
            <Counter
              count={facts.counter.count || 0}
              suffix={facts.counter.count_suffix}
              duration={facts.counter.count_duration}
              prefix={facts.counter.count_prefix}
              client:only="react"
            />
          </p>
        </div>

        <ul class="text-center lg:text-left space-y-px">
          {
            facts.dialogues?.map((fact, i) => (
              <li
                data-aos="fade-up-sm"
                data-aos-delay={i * 200 + 100}
                class="w-full"
              >
                <span
                  class="block mx-auto lg:mx-0 w-max bg-body text-text-dark text-sm font-medium px-4 py-px rounded-full"
                  set:html={markdownify(fact)}
                />
              </li>
            ))
          }
        </ul>
      </div>

      {/* Circle Background */}
      <div
        class="absolute top-[85%] lg:top-[70%] left-1/2 -translate-x-1/2 z-0 rounded-full bg-body/30"
        style="width: 90%; padding-bottom: 90%;"
      >
      </div>

      {/* CTA Image */}
      <ImageMod
        class="relative z-10 mx-auto -mt-[150px]"
        src={image!}
        alt="cta"
        width={880}
        height={680}
        loading={"lazy"}
        format="webp"
      />
    </div>
  </div>
</section>
