---
import ImageMod from "@/components/ImageMod.astro";
import Base from "@/layouts/Base.astro";
---

<Base title="Page Not Found">
  <section class="section-lg text-center">
    <div class="container section-lg pt-0">
      <div
        class="row justify-center"
        data-aos="fade-up-sm"
        data-aos-delay="150"
      >
        <div class="sm:col-10 md:col-8 lg:col-6">
          <ImageMod
            src="/images/404.png"
            alt="404"
            width={120}
            height={120}
            class="mx-auto mb-10"
            format="webp"
            loading={"eager"}
          />
          <h1 class="h2 mb-4">Sorry! Page not found</h1>
          <div class="content">
            <p>
              It looks like the page you’re looking for doesn’t exist or might
              have been moved. don’t worry, let’s get you back on track!
            </p>
          </div>
          <a
            data-aos="zoom-in-sm"
            data-aos-delay="300"
            href="/"
            class="btn btn-primary mt-6">Back to home</a
          >
        </div>
      </div>
    </div>
  </section>
</Base>
