---
import TitleBadge from "@/components/TitleBadge.astro";
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import CallToActionSecondary from "@/partials/CallToActionSecondary.astro";
import { render } from "astro:content";

// get static paths for all pages
export async function getStaticPaths() {
  const COLLECTION_FOLDER = "pages";

  const pages = await getSinglePage(COLLECTION_FOLDER);

  const paths = pages.map((page) => ({
    params: {
      regular: page.id,
    },
    props: { page },
  }));
  return paths;
}

const { page } = Astro.props;
const { title, meta_title, description, image, badge } = page.data;
const { Content } = await render(page);
---

<Base
  title={title}
  meta_title={meta_title}
  description={description}
  image={image}
>
  <section class="section-lg">
    <div class="container">
      {/* Section Title */}
      <div
        data-aos="fade-up-sm"
        data-aos-delay="100"
        class="row justify-center"
      >
        <div class="col-10 lg:col-6">
          {
            badge.enable && (
              <TitleBadge
                icon={badge.icon}
                label={badge.label}
                bg_color={badge.bg_color}
              />
            )
          }
          <h2 class="py-4 text-center" set:html={markdownify(title || "")} />
          <p
            class="text-center text-balance"
            set:html={markdownify(description || "")}
          />
        </div>
      </div>

      <div class="row justify-center mt-2">
        <div class="lg:col-8">
          <div data-aos="fade-up-sm" data-aos-delay="150" class="content">
            <Content />
          </div>
        </div>
      </div>
    </div>
  </section>

  <CallToActionSecondary isNoSectionTop={true} />
</Base>
