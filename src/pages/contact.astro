---
import { getBackgroundClass } from "@/components/Features.astro";
import TitleBadge from "@/components/TitleBadge.astro";
import config from "@/config/config.json";
import DynamicIcon from "@/helpers/DynamicIcon";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import CallToActionSecondary from "@/partials/CallToActionSecondary.astro";
import FAQs from "@/partials/FAQs.astro";

const contactIndex = await getListPage(
  "contact",
  "-index"
);
if(contactIndex.data.draft){
  return Astro.redirect("/404");
}
const { contact_form_action }: { contact_form_action: string } = config.params;
const { title, description, badge, cta_banners, contact_form_intro } =
  contactIndex.data;
---

<Base {...contactIndex.data}>
  <section class="section-lg">
    <div class="container">
      {/* Section Title */}
      <div
        data-aos="fade-up-sm"
        data-aos-delay="100"
        class="row justify-center"
      >
        <div class="col-10 lg:col-6">
          {
            badge.enable && (
              <TitleBadge
                icon={badge.icon}
                label={badge.label}
                bg_color={badge.bg_color}
              />
            )
          }
          <h2 class="py-4 text-center" set:html={markdownify(title || "")} />
          <p
            class="text-center text-balance"
            set:html={markdownify(description || "")}
          />
        </div>
      </div>

      <div class="pt-14">
        <div class="row g-4">
          {
            cta_banners?.map((banner, i) => (
              <div
                class="md:col-6 mx-auto"
                data-aos="fade-up-sm"
                data-aos-delay={100 * (i % 2)}
              >
                <div
                  class={`${banner.banner_color} rounded-4xl p-14 text-wrap break-words relative overflow-hidden`}
                >
                  {/* Circle Background */}
                  <div
                    class="absolute top-[70%] lg:top-[55%] left-1/2 -translate-x-1/2 z-0 rounded-full bg-body/30"
                    style="width: 100vw; height: 200vw;"
                  />

                  <div class="relative z-10 flex flex-col items-center">
                    <h3
                      class="mb-4 h4 font-semibold text-center"
                      set:html={markdownify(banner.title || "")}
                    />
                    <p
                      class="mb-6 text-center text-balance text-sm text-text-dark"
                      set:html={markdownify(banner.description || "")}
                    />
                    {banner.button?.enable && (
                      <a
                        href={banner.button.link}
                        class="btn btn-primary w-full text-center"
                      >
                        {banner.button.label}
                      </a>
                    )}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section class="section pt-0">
    <div class="container">
      {/* section title   */}
      <div class="row g-4 justify-between items-center">
        <div
          data-aos="fade-up-sm"
          data-aos-delay="200"
          class="lg:col-6 max-lg:text-center"
        >
          <TitleBadge
            icon={contact_form_intro.badge.icon}
            label={contact_form_intro.badge.label}
            bg_color={contact_form_intro.badge.bg_color}
            isCenter={false}
          />
          <h2
            class="py-4"
            set:html={markdownify(contact_form_intro.title || "")}
          />
          <p
            class="text-balance"
            set:html={markdownify(contact_form_intro.description || "")}
          />

          <div class="grid md:grid-cols-2 gap-4 pt-14">
            {
              contact_form_intro.highlights?.map((highlight, i) => {
                const bgClass = getBackgroundClass(i);
                return (
                  <div>
                    <div
                      class={`w-fit max-lg:mx-auto p-2 rounded-xl ${bgClass} mb-8`}
                    >
                      <DynamicIcon
                        icon={highlight.icon}
                        className="text-white text-xl"
                      />
                    </div>

                    <h6
                      class="font-semibold"
                      set:html={markdownify(highlight.title || "")}
                    />
                    <p
                      class="mt-3 mb-6"
                      set:html={markdownify(highlight.description || "")}
                    />
                  </div>
                );
              })
            }
          </div>
        </div>

        <div data-aos="fade-up-sm" data-aos-delay="200" class="lg:col-6">
          <div class="bg-dark/2 p-10 rounded-2xl">
            <h6 class="h4 mb-2 font-semibold">Let’s Chat</h6>
            <p>Want to learn more about Us, we are ready to help.</p>

            <form class="mt-8" action={contact_form_action} method="POST">
              <div class="mb-6">
                <label for="name" class="form-label">
                  Your Full Name <span>*</span>
                </label>
                <input
                  id="name"
                  name="name"
                  class="form-input"
                  placeholder="John Doe"
                  type="text"
                  required
                />
              </div>
              <div class="mb-6">
                <label for="email" class="form-label">
                  Your Email <span>*</span>
                </label>
                <input
                  id="email"
                  name="email"
                  class="form-input"
                  placeholder="john.doe@email.com"
                  type="email"
                  required
                />
              </div>
              <div class="mb-6">
                <label for="message" class="form-label">
                  Your Message <span>*</span>
                </label>
                <textarea
                  id="message"
                  name="message"
                  class="form-input"
                  placeholder="Write your message"
                  required
                  rows="6"></textarea>
              </div>
              <button type="submit" class="btn btn-primary w-full text-center"
                >Send Message</button
              >
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <FAQs />
  <CallToActionSecondary isNoSectionTop={true} />
</Base>
