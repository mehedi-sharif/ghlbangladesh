---
import PromotionsSection from "@/components/PromotionsSection.astro";
import SuccessNumbers from "@/components/SuccessNumbers.astro";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import CallToActionPrimary from "@/partials/CallToActionPrimary.astro";
import CallToActionSecondary from "@/partials/CallToActionSecondary.astro";
import CallToActionTertiary from "@/partials/CallToActionTertiary.astro";
import FAQs from "@/partials/FAQs.astro";
import FeaturesSection from "@/partials/FeaturesSection.astro";
import HeroBanner from "@/partials/HeroBanner.astro";
import ImpactResultsSection from "@/partials/ImpactResultsSection.astro";
import ProgramsSection from "@/partials/ProgramsSection.astro";
import ReviewSection from "@/partials/ReviewSection.astro";

const homepage = await getListPage(
  "homepage",
  "-index"
);

const { banner, promotions } = homepage.data;
---

<Base>
  <HeroBanner banner={banner} />
  <PromotionsSection promotions={promotions} />
  <ImpactResultsSection />
  <CallToActionPrimary />
  <ProgramsSection />
  <SuccessNumbers />
  <FeaturesSection />
  <CallToActionTertiary />
  <ReviewSection />
  <CallToActionSecondary />
  <FAQs />
</Base>
