---
import ReviewCard from "@/components/ReviewCard.astro";
import TitleBadge from "@/components/TitleBadge.astro";
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import CallToActionSecondary from "@/partials/CallToActionSecondary.astro";

const reviewsIndex = await getListPage(
  "reviews",
  "-index"
);
if(reviewsIndex.data.draft){
  return Astro.redirect("/404");
}

const reviewsSection = await getListPage(
  "reviewsSection",
  "reviews-section"
);
---

<Base {...reviewsIndex.data}>
  <section class="section-lg">
    <div class="container">
      {/* Section Title */}
      <div
        data-aos="fade-up-sm"
        data-aos-delay="100"
        class="row justify-center"
      >
        <div class="col-10 lg:col-6">
          {
            reviewsIndex.data.badge.enable && (
              <TitleBadge
                icon={reviewsIndex.data.badge.icon}
                label={reviewsIndex.data.badge.label}
                bg_color={reviewsIndex.data.badge.bg_color}
              />
            )
          }
          <h2
            class="py-4 text-center"
            set:html={markdownify(reviewsIndex.data.title || "")}
          />
          <p
            class="text-center text-balance"
            set:html={markdownify(reviewsIndex.data.description || "")}
          />
        </div>
      </div>

      {reviewsSection.data.enable && (
        <div class="pt-14">
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 h-auto">
            {
              reviewsSection.data?.reviews?.map((review, i) => (
              <ReviewCard review={review} index={i} />
            ))
          }
        </div>
      </div>)
      }
    </div>
  </section>

  <CallToActionSecondary isNoSectionTop />
</Base>
